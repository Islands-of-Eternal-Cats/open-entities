{
    "name": "open-entities-js-app",
    "version": "0.1.0",
    "description": "JavaScript app using open-entities WASM bindings",
    "type": "module",
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "build:wasm": "cd ../wasm-bindings && wasm-pack build --target web",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:run": "vitest run"
    },
    "dependencies": {
        "open-entities-wasm": "file:../wasm-bindings/pkg",
        "pixi.js": "^8.17.1"
    },
    "devDependencies": {
        "jsdom": "^29.0.1",
        "typescript": "^6.0.2",
        "vite": "^8.0.3",
        "vitest": "^4.1.2"
    },
    "overrides": {
        "@xmldom/xmldom": "^0.8.12"
    }
}
